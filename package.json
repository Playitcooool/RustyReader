{
  "name": "rustyreader",
  "version": "1.0.0",
  "description": "A desktop application for reading, organizing, and researching academic papers",
  "author": "Codex",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "node -e \"console.error('Tauri-only app: use `npm run tauri:dev` (desktop) instead of `npm run dev`.'); process.exit(1)\"",
    "dev:tauri": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "verify": "bash scripts/verify.sh",
    "extension:test": "npm --prefix extensions/chrome test",
    "extension:smoke": "npm --prefix extensions/chrome run smoke",
    "extension:build": "node scripts/build-browser-extensions.js",
    "extension:package": "npm --prefix extensions/chrome run package",
    "extension:safari:build": "npm --prefix extensions/safari run build",
    "extension:safari:zip": "npm --prefix extensions/safari run zip",
    "extension:safari:package": "npm --prefix extensions/safari run package",
    "extension:safari:install": "npm --prefix extensions/safari run install:persistent",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@mdxeditor/editor": "^4.0.1",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "katex": "^0.17.0",
    "pdfjs-dist": "^5.6.205",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
